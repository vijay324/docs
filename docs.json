{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flotick Docs",
  "description": "Flotick is an organization-first work operating system for delivery, workforce operations, and platform governance.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#166534"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@flotick.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://app.flotick.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart",
              "getting-started/onboarding",
              "getting-started/first-week-checklist"
            ]
          }
        ]
      },
      {
        "tab": "Features",
        "groups": [
          {
            "group": "Plan and deliver work",
            "pages": [
              "features/dashboard",
              "features/projects",
              "features/tasks",
              "features/sprints",
              "features/analytics",
              "features/ai-insights"
            ]
          },
          {
            "group": "Run team operations",
            "pages": [
              "features/attendance",
              "features/leave",
              "features/payroll",
              "features/employees"
            ]
          }
        ]
      },
      {
        "tab": "Workflows",
        "groups": [
          {
            "group": "Daily execution",
            "pages": [
              "workflows/daily-routine",
              "workflows/sprint-planning",
              "workflows/team-lead-rhythm",
              "workflows/month-end-operations"
            ]
          }
        ]
      },
      {
        "tab": "Use Cases",
        "groups": [
          {
            "group": "By team type",
            "pages": [
              "use-cases/engineering-teams",
              "use-cases/operations-hr-teams",
              "use-cases/growing-organizations",
              "use-cases/remote-hybrid-teams"
            ]
          }
        ]
      },
      {
        "tab": "Help",
        "groups": [
          {
            "group": "Support",
            "pages": [
              "reference/faq",
              "reference/feature-matrix"
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/flotick",
      "github": "https://github.com/flotick",
      "linkedin": "https://linkedin.com/company/flotick"
    }
  }
}
