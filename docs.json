            "group": "Your account",
            "pages": [
              "account/profile",
              "account/security-and-2fa"
            ]
          }
        ]
      },
      {
        "tab": "Help",
        "groups": [
          {
            "group": "Product help",
            "pages": [
              "resources/feature-requests",
              "resources/feedback",
              "resources/feature-matrix",
              "resources/security",
              "resources/faq",
              "resources/glossary",
              "resources/support"
            ]
          }
        ]
      }
