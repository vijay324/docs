{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flotick Docs",
  "description": "Guides for planning work, running team operations, and using Orbit in Flotick.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#166534"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      { "label": "Support", "href": "mailto:support@flotick.com" },
      { "label": "Pricing", "href": "https://flotick.com/pricing" }
    ],
    "primary": {
      "type": "button",
      "label": "Open Flotick",
      "href": "https://flotick.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get started",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "get-started/quickstart",
              "get-started/core-concepts",
              "get-started/navigation"
            ]
          },
          {
            "group": "Access your organization",
            "pages": [
              "get-started/sign-up",
              "get-started/accept-invitation",
              "get-started/onboarding"
            ]
          }
        ]
      },
      {
        "tab": "Work management",
        "groups": [
          {
            "group": "Your work",
            "pages": [
              "features/inbox",
              "features/tasks",
              "features/personal-board"
            ]
          },
          {
            "group": "Plan and deliver",
            "pages": [
              "features/projects",
              "features/sprints",
              "features/recurring-tasks",
              "features/task-dependencies"
            ]
          },
          {
            "group": "Collaborate",
            "pages": [
              "features/comments",
              "features/files",
              "features/notifications",
              "features/realtime"
            ]
          },
          {
            "group": "Developer workflows",
            "pages": [
              "features/env-storage",
              "features/trash"
            ]
          }
        ]
      },
      {
        "tab": "Team operations",
        "groups": [
          {
            "group": "Time and time off",
            "pages": [
              "features/attendance",
              "features/leave",
              "features/holidays",
              "features/shifts"
            ]
          },
          {
            "group": "Administration",
            "pages": [
              "admin/members-and-roles",
              "admin/member-permissions",
              "admin/departments",
              "admin/attendance-policy",
              "admin/leave-policy"
            ]
          }
        ]
      },
      {
        "tab": "Orbit and analytics",
        "groups": [
          {
            "group": "Orbit",
            "pages": [
              "features/orbit",
              "features/ai-agent",
              "features/ai-summaries",
              "features/ai-enhance"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "features/analytics",
              "features/scheduled-reports"
            ]
          }
        ]
      },
      {
        "tab": "Admin and account",
        "groups": [
          {
            "group": "Organization settings",
            "pages": [
              "admin/organization-settings",
              "admin/workflow-policy",
              "admin/labels"
            ]
          },
          {
            "group": "Plans and billing",
            "pages": [
              "admin/billing/plans",
              "admin/billing/upgrade-or-cancel",
              "admin/billing/seat-management",
              "admin/billing/plan-enforcement"
            ]
          },
